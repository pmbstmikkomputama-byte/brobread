rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Auth tokens don't have roles, so we check the user document
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'admin';
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can see other staff
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      
      // Bootstrap Rule: Allow user to create their own record if they are 'admin@brobread.internal'
      // or if they are being created by an existing admin.
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (request.auth.token.email == "admin@brobread.internal") || 
        (incoming().role == "kasir") ||
        (isAdmin())
      );
      
      allow update: if (isAdmin() || (request.auth.uid == userId && incoming().role == existing().role)) && isValidUser(incoming());

      function isValidUser(data) {
        return data.keys().hasAll(['id', 'name', 'username', 'role']) &&
               data.id is string && data.id.size() <= 128 &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.username is string && data.username.size() > 0 && data.username.size() <= 50 &&
               data.role in ['admin', 'kasir'];
      }
    }

    // --- Products Collection ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(productId) && isValidProduct(incoming());

      function isValidProduct(data) {
        return data.keys().hasAll(['id', 'name', 'price', 'category', 'image', 'description']) &&
               data.id is string && data.id.size() <= 128 &&
               data.name is string && data.name.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               data.category is string && data.category.size() <= 50 &&
               data.image is string && data.image.size() <= 1000 &&
               data.description is string && data.description.size() <= 1000 &&
               data.keys().size() == 6;
      }
    }

    // --- Transactions Collection ---
    match /transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(txId) && isValidTransaction(incoming());
      // Updates only by admin, typically for notes or corrections
      allow update: if isAdmin() && isValidTransaction(incoming());
      allow delete: if isAdmin();

      function isValidTransaction(data) {
        return data.keys().hasAll(['id', 'items', 'total', 'timestamp', 'paymentMethod']) &&
               data.id is string && data.id.size() <= 128 &&
               data.total is number && data.total >= 0 &&
               data.paymentMethod in ['cash', 'e-wallet', 'card'] &&
               data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
               // We don't check for custom fields to allow editLogs
               data.keys().hasAll(['id', 'items', 'total', 'timestamp', 'paymentMethod']);
      }
    }

    // --- System Configs ---
    match /systemConfigs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(configId) && isValidConfig(incoming());

      function isValidConfig(data) {
        return data.keys().hasAll(['name', 'logo']) &&
               data.name is string && data.name.size() <= 50 &&
               data.logo is string && data.logo.size() <= 2;
      }
    }
  }
}
