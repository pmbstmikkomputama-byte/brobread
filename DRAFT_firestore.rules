rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;

      function isValidUser(data) {
        return data.keys().hasAll(['id', 'name', 'username', 'role']) &&
               data.id is string && data.name is string && data.name.size() <= 100 &&
               data.username is string && data.username.size() <= 50 &&
               data.role in ['admin', 'kasir'];
      }
    }

    // --- Products Collection ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidProduct(incoming());

      function isValidProduct(data) {
        return data.keys().hasAll(['id', 'name', 'price', 'category', 'image', 'description']) &&
               data.id is string && data.name is string && data.name.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               data.category is string && data.image is string &&
               data.description is string && data.description.size() <= 500;
      }
    }

    // --- Transactions Collection ---
    match /transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isAdmin() && isValidTransaction(incoming());
      allow delete: if isAdmin();

      function isValidTransaction(data) {
        return data.keys().hasAll(['id', 'items', 'total', 'timestamp', 'paymentMethod']) &&
               data.id is string && data.total is number && data.total >= 0 &&
               data.paymentMethod in ['cash', 'e-wallet', 'card'] &&
               data.items is list && data.items.size() > 0;
      }
    }

    // --- System Configs ---
    match /systemConfigs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidConfig(incoming());

      function isValidConfig(data) {
        return data.keys().hasAll(['name', 'logo']) &&
               data.name is string && data.name.size() <= 50 &&
               data.logo is string && data.logo.size() <= 2;
      }
    }
  }
}
